{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.env-vars.v1.schema.json",
  "title": "Harness Env Vars Config v1",
  "type": "object",
  "required": ["version", "vars"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "env_example": {
      "type": "string",
      "minLength": 1
    },
    "ignored": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "vars": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "default", "relevance"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]+$"
          },
          "default": {
            "type": "string"
          },
          "relevance": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "in_env_example": {
            "type": "boolean"
          }
        },
        "patternProperties": {
          "^x-": {}
        },
        "additionalProperties": false
      }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}

