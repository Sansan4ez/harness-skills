{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.traceability.v1.schema.json",
  "title": "Harness Traceability Config v1",
  "type": "object",
  "required": ["version", "requirements", "openapi"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "requirements": {
      "type": "object",
      "required": ["sources", "id_pattern"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "id_pattern": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    },
    "openapi": {
      "type": "object",
      "required": ["requirement_extension"],
      "properties": {
        "requirement_extension": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    },
    "tests": {
      "type": "object",
      "properties": {
        "marker": { "type": "string", "minLength": 1 },
        "allow_unmarked_tests": { "type": "boolean" },
        "openapi_requirements_coverage": {
          "type": "string",
          "enum": ["off", "warn", "error"]
        }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}
