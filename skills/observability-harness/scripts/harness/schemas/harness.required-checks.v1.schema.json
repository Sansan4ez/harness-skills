{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.required-checks.v1.schema.json",
  "title": "Harness Required Checks Contract v1",
  "type": "object",
  "required": ["version", "checks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "workflow_file", "workflow_name", "job", "required", "gating"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "workflow_file": { "type": "string", "minLength": 1 },
        "workflow_name": { "type": "string", "minLength": 1 },
        "job": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gating": {
          "type": "object",
          "required": ["on_pull_request", "on_push_main"],
          "properties": {
            "on_pull_request": {
              "type": "string",
              "enum": ["required", "label", "manual"]
            },
            "label": { "type": "string", "minLength": 1 },
            "on_push_main": {
              "type": "string",
              "enum": ["required", "manual"]
            },
            "on_release": {
              "type": "string",
              "enum": ["required", "manual"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
