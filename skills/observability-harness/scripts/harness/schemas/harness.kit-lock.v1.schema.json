{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.kit-lock.v1.schema.json",
  "title": "Harness Kit Lock v1",
  "type": "object",
  "required": ["version", "kit", "modules", "applied_at", "managed_files"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "kit": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["docs", "traceability", "observability"]
      }
    },
    "applied_at": {
      "type": "string",
      "format": "date-time"
    },
    "managed_files": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}
