{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.observability.baseline.v1.schema.json",
  "title": "Harness Observability Baseline Config v1",
  "type": "object",
  "required": ["version", "stack", "app", "smoke"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "stack": {
      "type": "object",
      "required": ["victoriametrics_dir", "compose_file"],
      "properties": {
        "victoriametrics_dir": { "type": "string", "minLength": 1 },
        "compose_file": { "type": "string", "minLength": 1 }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    },
    "app": {
      "type": "object",
      "required": ["compose_files"],
      "properties": {
        "compose_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    },
    "smoke": {
      "type": "object",
      "required": ["pr_label", "health_timeout_seconds", "required_on"],
      "properties": {
        "pr_label": { "type": "string", "minLength": 1 },
        "health_timeout_seconds": { "type": "integer", "minimum": 1 },
        "artifacts_dir": { "type": "string", "minLength": 1 },
        "required_on": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "patternProperties": {
        "^x-": {}
      },
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}
