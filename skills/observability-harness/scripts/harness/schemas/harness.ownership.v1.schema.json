{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repo-harness-kit.local/schemas/harness.ownership.v1.schema.json",
  "title": "Harness Ownership Override v1",
  "type": "object",
  "required": ["version", "kit_managed", "project_owned"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "kit_managed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "project_owned": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}
